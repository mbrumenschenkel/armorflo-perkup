# ─────────────────────────────────────────────
# ArmorFlo Perk Up — SMS Backend Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.
# ─────────────────────────────────────────────

# Twilio credentials (twilio.com/console)
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Email (for customer confirmations) — uses Gmail SMTP by default
# Any SMTP provider works: SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rewards@yourdomain.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="ArmorFlo Perk Up <rewards@yourdomain.com>"

# Optional: reward link base URL sent to approved customers
REWARD_LINK_BASE=https://www.cadenceperkup.com/claim

# Admin API authentication
# Required header on /api/admin/* requests (either
# "Authorization: Bearer <key>" or "X-Admin-Token: <key>").
# If blank, admin routes are UNAUTHENTICATED — do not ship to production blank.
ADMIN_API_KEY=

# CORS — comma-separated origins allowed to call /api/* endpoints.
# Example: https://www.cadenceperkup.com,https://admin.cadenceperkup.com
ALLOWED_ORIGINS=

# Server
PORT=3000
NODE_ENV=production
